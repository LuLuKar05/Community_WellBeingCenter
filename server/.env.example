# ── Server ────────────────────────────────────────────────────────────────────
# HTTP port. Leave as 5000 for local development.
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string.
# Get it from: Atlas dashboard → Connect → Drivers → copy the URI.
# Replace <username>, <password>, and <dbname> with your values.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin allowed to call this API.
# Local development: http://localhost:3000
# Production: change to your deployed frontend URL (e.g. https://yourapp.vercel.app)
CLIENT_URL=http://localhost:3000

# ── Clerk (Auth) ──────────────────────────────────────────────────────────────
# Get both keys from: Clerk dashboard → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
# Get from: Stripe dashboard → Developers → API keys
# Use sk_test_... for development, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret.
# Local: run `stripe listen --forward-to localhost:5000/api/webhook` and copy the printed secret.
# Production: add the endpoint in Stripe dashboard and copy the secret from there.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── OpenAI (Chatbot embeddings) ───────────────────────────────────────────────
# Get from: platform.openai.com → API Keys
# Used by the RAG pipeline to convert text into vector embeddings.
OPENAI_API_KEY=sk-REPLACE_ME

# ── FLock / Z.AI (Chatbot completions) ───────────────────────────────────────
# Get from your FLock / Z.AI dashboard.
FLOCK_API_KEY=sk-REPLACE_ME
FLOCK_BASE_URL=https://api.flock.io/v1
